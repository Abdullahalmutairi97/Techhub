<% showHero = false; activeCategory = null; search = null; %>
<%- include('partials/header') %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <div class="auth-icon mb-2"><i class="bi bi-key-fill"></i></div>
      <h4 class="fw-700 mb-1" style="font-weight:700;letter-spacing:-0.02em;">Reset your password</h4>
      <p class="text-muted" style="font-size:0.875rem;">Enter your email and we'll send you a reset link</p>
    </div>

    <% if (typeof sent !== 'undefined' && sent) { %>
      <div class="p-4 rounded text-center" style="background:#f0fdf4;border:1.5px solid #bbf7d0;">
        <i class="bi bi-check-circle-fill text-success fs-3 mb-2 d-block"></i>
        <div style="font-weight:600;color:#166534;margin-bottom:0.25rem;">Check your email</div>
        <div style="font-size:0.8125rem;color:#15803d;">If an account exists, a reset link has been sent.</div>
      </div>
      <div class="text-center mt-4">
        <a href="/login" class="btn btn-primary px-4">Back to Sign In</a>
      </div>
    <% } else { %>
      <form action="/forgot-password" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="mb-4">
          <label class="form-label">Email Address</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" name="email" class="form-control" placeholder="Enter your account email"
              required autocomplete="email" />
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100" style="padding:0.65rem;">Send Reset Link</button>
      </form>
      <div class="text-center mt-4" style="font-size:0.875rem;color:#6b7280;">
        Remember your password?
        <a href="/login" style="color:#2563eb;text-decoration:none;font-weight:600;">Sign in</a>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

