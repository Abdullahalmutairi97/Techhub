<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' - TechHub' : 'TechHub' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<% if (typeof flash !== 'undefined' && flash) { %>
<div class="flash-container">
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
    <i class="bi bi-<%= flash.type === 'success' ? 'check-circle' : 'exclamation-circle' %>-fill me-2"></i>
    <%= flash.msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
</div>
<% } %>

<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/"><span class="brand-pc">Tech</span><span class="brand-parts">Hub</span></a>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <i class="bi bi-list fs-4 text-secondary"></i>
    </button>

    <div class="collapse navbar-collapse" id="navMain">
      <ul class="navbar-nav me-auto gap-1 ms-3">
        <li class="nav-item">
          <a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Home</a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-grid me-1"></i>Categories
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/?category=CPU"><i class="bi bi-cpu me-2 text-primary"></i>CPU</a></li>
            <li><a class="dropdown-item" href="/?category=Motherboard"><i class="bi bi-motherboard me-2 text-primary"></i>Motherboard</a></li>
            <li><a class="dropdown-item" href="/?category=RAM"><i class="bi bi-memory me-2 text-primary"></i>RAM</a></li>
            <li><a class="dropdown-item" href="/?category=GPU"><i class="bi bi-gpu-card me-2 text-primary"></i>GPU</a></li>
            <li><hr class="dropdown-divider my-1" /></li>
            <li><a class="dropdown-item" href="/?category=Storage"><i class="bi bi-device-hdd me-2 text-primary"></i>Storage</a></li>
            <li><a class="dropdown-item" href="/?category=PSU"><i class="bi bi-battery-charging me-2 text-primary"></i>PSU</a></li>
            <li><a class="dropdown-item" href="/?category=Cooling"><i class="bi bi-thermometer-snow me-2 text-primary"></i>Cooling</a></li>
            <li><a class="dropdown-item" href="/?category=Case"><i class="bi bi-box me-2 text-primary"></i>Case</a></li>
            <li><a class="dropdown-item" href="/?category=Mini+PC"><i class="bi bi-pc me-2 text-primary"></i>Mini PC</a></li>
          </ul>
        </li>
      </ul>

      <ul class="navbar-nav align-items-center gap-2">
        <li class="nav-item">
          <a class="nav-cart-btn" href="/cart">
            <i class="bi bi-bag"></i>
            <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
              <span class="cart-badge"><%= cartCount %></span>
            <% } %>
          </a>
        </li>

        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item">
            <a class="nav-cart-btn" href="/wishlist" title="Wishlist">
              <i class="bi bi-heart"></i>
            </a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
              <span class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle" style="width:28px;height:28px;font-size:0.75rem;font-weight:700;">
                <%= (user.firstName || user.uName || 'U')[0].toUpperCase() %>
              </span>
              <span style="font-size:0.875rem;font-weight:600;color:#374151;"><%= user.firstName || user.uName %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
              <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag-check me-2"></i>Orders</a></li>
              <li><a class="dropdown-item" href="/wishlist"><i class="bi bi-heart me-2"></i>Wishlist</a></li>
              <li><hr class="dropdown-divider" /></li>
              <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/register" style="font-size:0.875rem;font-weight:500;">Register</a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn-login" href="/login">Sign in</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (typeof showHero === 'undefined' || showHero !== false) { %>
<% if (typeof activeCategory === 'undefined' || (!activeCategory && (typeof search === 'undefined' || !search))) { %>

<div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
  </div>

  <div class="carousel-inner">
    <!-- Slide 1 -->
    <div class="carousel-item active">
      <div class="hero-banner">
        <div class="container">
          <div class="hero-banner-inner">
            <div>
              <span class="hero-eyebrow">2024 Components In Stock</span>
              <h1 class="hero-title">Build Your <span>Dream PC</span><br/>Without the Hassle</h1>
              <p class="hero-sub">Top-tier CPUs, GPUs, RAM, and more from Intel, AMD, NVIDIA — all in one place.</p>
              <div class="d-flex gap-3 flex-wrap">
                <a href="/?category=CPU" class="btn btn-primary px-4 py-2">Shop CPUs</a>
                <a href="/?category=GPU" class="btn btn-outline-light px-4 py-2">Shop GPUs</a>
              </div>
            </div>
            <div class="hero-stats d-none d-lg-flex">
              <div class="hero-stat"><div class="hero-stat-num">200+</div><div class="hero-stat-label">Products</div></div>
              <div class="hero-stat"><div class="hero-stat-num">9</div><div class="hero-stat-label">Categories</div></div>
              <div class="hero-stat"><div class="hero-stat-num">Free</div><div class="hero-stat-label">Shipping</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="carousel-item">
      <div class="hero-banner hero-banner--alt1">
        <div class="container">
          <div class="hero-banner-inner">
            <div>
              <span class="hero-eyebrow">Latest GPUs Available</span>
              <h1 class="hero-title">Power Your <span>Graphics</span><br/>Like Never Before</h1>
              <p class="hero-sub">RTX 4090, RX 7900 XTX, and more. Dominate 4K gaming and content creation.</p>
              <div class="d-flex gap-3 flex-wrap">
                <a href="/?category=GPU" class="btn btn-primary px-4 py-2">Shop GPUs</a>
                <a href="/?category=CPU" class="btn btn-outline-light px-4 py-2">Shop CPUs</a>
              </div>
            </div>
            <div class="hero-stats d-none d-lg-flex">
              <div class="hero-stat"><div class="hero-stat-num">RTX</div><div class="hero-stat-label">4090 In Stock</div></div>
              <div class="hero-stat"><div class="hero-stat-num">4K</div><div class="hero-stat-label">Ready GPUs</div></div>
              <div class="hero-stat"><div class="hero-stat-num">Free</div><div class="hero-stat-label">Shipping</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="carousel-item">
      <div class="hero-banner hero-banner--alt2">
        <div class="container">
          <div class="hero-banner-inner">
            <div>
              <span class="hero-eyebrow">Complete Your Build</span>
              <h1 class="hero-title">Cases, Cooling<br/>&amp; <span>Everything Else</span></h1>
              <p class="hero-sub">PSUs, cases, coolers, RAM — everything you need to finish your perfect build.</p>
              <div class="d-flex gap-3 flex-wrap">
                <a href="/?category=Case" class="btn btn-primary px-4 py-2">Shop Cases</a>
                <a href="/?category=Cooling" class="btn btn-outline-light px-4 py-2">Shop Cooling</a>
              </div>
            </div>
            <div class="hero-stats d-none d-lg-flex">
              <div class="hero-stat"><div class="hero-stat-num">30</div><div class="hero-stat-label">Day Returns</div></div>
              <div class="hero-stat"><div class="hero-stat-num">2yr</div><div class="hero-stat-label">Warranty</div></div>
              <div class="hero-stat"><div class="hero-stat-num">Free</div><div class="hero-stat-label">Shipping</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<% } %>
<% } %>

