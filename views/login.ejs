<% showHero = false; activeCategory = null; search = null; %>
<%- include('partials/header') %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <div class="auth-icon mb-2"><i class="bi bi-cpu-fill"></i></div>
      <h4 class="fw-700 mb-1" style="font-weight:700;letter-spacing:-0.02em;">Welcome back</h4>
      <p class="text-muted" style="font-size:0.875rem;">Sign in to your TechHub account</p>
    </div>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert" style="font-size:0.875rem;">
        <% errors.forEach(function(e) { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }); %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <form action="/login" method="POST" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="mb-3">
        <label class="form-label">Username or Email</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-person"></i></span>
          <input type="text" name="identifier" class="form-control" placeholder="Enter username or email"
            required autocomplete="username" />
        </div>
      </div>
      <div class="mb-1">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <label class="form-label mb-0">Password</label>
          <a href="/forgot-password" style="font-size:0.8rem;color:#2563eb;text-decoration:none;">Forgot password?</a>
        </div>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-lock"></i></span>
          <input type="password" name="password" class="form-control" placeholder="Enter your password"
            required autocomplete="current-password" />
        </div>
      </div>
      <div class="mb-4 mt-2">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="rememberMe" />
          <label class="form-check-label text-muted" for="rememberMe" style="font-size:0.8125rem;">Remember me</label>
        </div>
      </div>
      <button type="submit" class="btn btn-primary w-100" style="padding:0.65rem;">Sign In</button>
    </form>

    <div class="text-center mt-4" style="font-size:0.875rem;color:#6b7280;">
      Don't have an account?
      <a href="/register" style="color:#2563eb;text-decoration:none;font-weight:600;">Create one free</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

