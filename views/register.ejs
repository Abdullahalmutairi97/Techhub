<% showHero = false; activeCategory = null; search = null; %>
<%- include('partials/header') %>

<div class="auth-wrapper">
  <div class="auth-card" style="max-width:500px;">
    <div class="text-center mb-4">
      <div class="auth-icon mb-2"><i class="bi bi-cpu-fill"></i></div>
      <h4 class="fw-700 mb-1" style="font-weight:700;letter-spacing:-0.02em;">Create an account</h4>
      <p class="text-muted" style="font-size:0.875rem;">Join TechHub and start building today</p>
    </div>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert" style="font-size:0.875rem;">
        <% errors.forEach(function(e) { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }); %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <form action="/register" method="POST" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="row g-3">
        <div class="col-6">
          <label class="form-label">First Name</label>
          <input type="text" name="firstName" class="form-control" placeholder="John"
            value="<%= typeof formData !== 'undefined' && formData.firstName ? formData.firstName : '' %>" />
        </div>
        <div class="col-6">
          <label class="form-label">Last Name</label>
          <input type="text" name="lastName" class="form-control" placeholder="Doe"
            value="<%= typeof formData !== 'undefined' && formData.lastName ? formData.lastName : '' %>" />
        </div>
        <div class="col-12">
          <label class="form-label">Username <span class="text-danger">*</span></label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-at"></i></span>
            <input type="text" name="username" class="form-control" placeholder="johndoe123" required
              value="<%= typeof formData !== 'undefined' && formData.username ? formData.username : '' %>"
              autocomplete="username" />
          </div>
          <div class="form-text" style="font-size:0.775rem;">At least 3 characters</div>
        </div>
        <div class="col-12">
          <label class="form-label">Email Address <span class="text-danger">*</span></label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" name="email" class="form-control" placeholder="john@example.com" required
              value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
              autocomplete="email" />
          </div>
        </div>
        <div class="col-12">
          <label class="form-label">Phone <span class="text-muted fw-normal">(optional)</span></label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
            <input type="tel" name="phone" class="form-control" placeholder="+1 (555) 000-0000"
              value="<%= typeof formData !== 'undefined' && formData.phone ? formData.phone : '' %>" />
          </div>
        </div>
        <div class="col-12">
          <label class="form-label">Address <span class="text-muted fw-normal">(optional)</span></label>
          <textarea name="address" class="form-control" rows="2" placeholder="123 Main St, City, State ZIP"><%= typeof formData !== 'undefined' && formData.address ? formData.address : '' %></textarea>
        </div>
        <div class="col-12">
          <label class="form-label">Password <span class="text-danger">*</span></label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input type="password" name="password" class="form-control" placeholder="Minimum 8 characters"
              required autocomplete="new-password" />
          </div>
        </div>
        <div class="col-12">
          <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter password"
              required autocomplete="new-password" />
          </div>
        </div>
        <div class="col-12 mt-1">
          <button type="submit" class="btn btn-primary w-100" style="padding:0.65rem;">Create Account</button>
        </div>
      </div>
    </form>

    <div class="text-center mt-4" style="font-size:0.875rem;color:#6b7280;">
      Already have an account?
      <a href="/login" style="color:#2563eb;text-decoration:none;font-weight:600;">Sign in</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

