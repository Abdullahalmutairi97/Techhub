<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PCParts — Your PC Component Store</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<% if (typeof flash !== 'undefined' && flash) { %>
<div class="flash-container">
  <div class="alert alert-<%= flash.type %> alert-dismissible fade show shadow" role="alert">
    <i class="bi bi-<%= flash.type === 'success' ? 'check-circle' : 'exclamation-triangle' %>-fill me-2"></i>
    <%= flash.msg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
</div>
<% } %>

<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/"><span class="brand-pc">PC</span><span class="brand-parts">Parts</span></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon" style="filter:invert(1);"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Home</a></li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-grid me-1"></i>Categories</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/?category=CPU"><i class="bi bi-cpu me-2"></i>CPU</a></li>
            <li><a class="dropdown-item" href="/?category=Motherboard"><i class="bi bi-motherboard me-2"></i>Motherboard</a></li>
            <li><a class="dropdown-item" href="/?category=RAM"><i class="bi bi-memory me-2"></i>RAM</a></li>
            <li><a class="dropdown-item" href="/?category=GPU"><i class="bi bi-gpu-card me-2"></i>GPU</a></li>
            <li><a class="dropdown-item" href="/?category=Storage"><i class="bi bi-device-hdd me-2"></i>Storage</a></li>
            <li><a class="dropdown-item" href="/?category=PSU"><i class="bi bi-battery-charging me-2"></i>PSU</a></li>
            <li><a class="dropdown-item" href="/?category=Cooling"><i class="bi bi-thermometer-snow me-2"></i>Cooling</a></li>
            <li><a class="dropdown-item" href="/?category=Case"><i class="bi bi-box me-2"></i>Case</a></li>
            <li><a class="dropdown-item" href="/?category=Mini+PC"><i class="bi bi-pc me-2"></i>Mini PC</a></li>
          </ul>
        </li>
      </ul>
      <ul class="navbar-nav align-items-center gap-2">
        <li class="nav-item">
          <a class="nav-link position-relative" href="/cart">
            <i class="bi bi-cart3 fs-5"></i>
            <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
              <span class="position-absolute badge rounded-pill cart-badge"><%= cartCount %></span>
            <% } %>
          </a>
        </li>
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item">
            <a class="nav-link position-relative" href="/wishlist" title="Wishlist">
              <i class="bi bi-heart fs-5"></i>
            </a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user.firstName || user.uName %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
              <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag-check me-2"></i>Order History</a></li>
              <li><a class="dropdown-item" href="/wishlist"><i class="bi bi-heart me-2"></i>Wishlist</a></li>
              <li><hr class="dropdown-divider" /></li>
              <li><a class="dropdown-item" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/register"><i class="bi bi-person-plus me-1"></i>Register</a></li>
          <li class="nav-item"><a class="btn btn-sm" href="/login" style="background:var(--cyan);color:#000;font-weight:600;border-radius:20px;padding:5px 16px;"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (typeof showHero === 'undefined' || showHero !== false) { %>
<% if (typeof activeCategory === 'undefined' || (!activeCategory && (typeof search === 'undefined' || !search))) { %>
<div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel">
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
  </div>
  <div class="carousel-inner">
    <div class="carousel-item active hero-slide-1">
      <div class="container d-flex align-items-center" style="height:420px;">
        <div class="carousel-caption text-start">
          <h1>Build Your <span style="color:var(--cyan);">Dream PC</span></h1>
          <p class="lead">Top-tier CPUs, GPUs, and more from the world's leading brands.</p>
          <a href="/?category=CPU" class="btn btn-primary btn-lg me-2">Shop CPUs</a>
          <a href="/?category=GPU" class="btn btn-outline-light btn-lg">Shop GPUs</a>
        </div>
      </div>
    </div>
    <div class="carousel-item hero-slide-2">
      <div class="container d-flex align-items-center" style="height:420px;">
        <div class="carousel-caption text-start">
          <h1>Next-Gen <span style="color:#69f0ae;">Storage</span> & RAM</h1>
          <p class="lead">PCIe 5.0 NVMe SSDs and DDR5 kits for blazing-fast performance.</p>
          <a href="/?category=Storage" class="btn btn-success btn-lg me-2">Shop Storage</a>
          <a href="/?category=RAM" class="btn btn-outline-light btn-lg">Shop RAM</a>
        </div>
      </div>
    </div>
    <div class="carousel-item hero-slide-3">
      <div class="container d-flex align-items-center" style="height:420px;">
        <div class="carousel-caption text-start">
          <h1>Compact <span style="color:#ce93d8;">Mini PCs</span></h1>
          <p class="lead">MINISFORUM & Beelink mini PCs — desktop power in your palm.</p>
          <a href="/?category=Mini+PC" class="btn btn-lg me-2" style="background:#7b2ff7;color:#fff;">Shop Mini PCs</a>
          <a href="/?category=Cooling" class="btn btn-outline-light btn-lg">Shop Cooling</a>
        </div>
      </div>
    </div>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
</div>
<% } %>
<% } %>
