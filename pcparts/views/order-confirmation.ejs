<% showHero = false; activeCategory = null; search = null; %>
<%- include('partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="card border-0 shadow-lg text-center p-5">
        <div class="confirm-icon mb-3"><i class="bi bi-check-circle-fill"></i></div>
        <h2 class="fw-bold mb-1">Order Placed!</h2>
        <p class="text-muted mb-4">Thank you for your purchase. Your order has been received and is being processed.</p>
        <div class="card bg-light border-0 mb-4 text-start p-4">
          <div class="row g-3">
            <div class="col-6"><div class="small text-muted mb-1">Order ID</div><div class="fw-bold">#<%= orderId %></div></div>
            <div class="col-6"><div class="small text-muted mb-1">Order Total</div><div class="fw-bold text-primary">$<%= total %></div></div>
            <div class="col-6"><div class="small text-muted mb-1">Status</div><span class="badge bg-warning text-dark">Pending</span></div>
            <div class="col-6"><div class="small text-muted mb-1">Payment</div><span class="badge bg-secondary">Processing</span></div>
            <div class="col-12"><div class="small text-muted mb-1">Shipping To</div><div class="fw-semibold"><%= shippingAddress %></div></div>
          </div>
        </div>
        <div class="alert alert-info d-flex align-items-start gap-2 text-start mb-4" role="alert">
          <i class="bi bi-envelope-fill mt-1 flex-shrink-0"></i>
          <div>An order confirmation email has been sent to <strong><%= user.email %></strong>. Please check your inbox.</div>
        </div>
        <a href="/" class="btn btn-primary btn-lg px-4"><i class="bi bi-grid me-2"></i>Continue Shopping</a>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
