<% showHero = false; activeCategory = null; search = null; %>
<%- include('partials/header') %>

<div class="page-header">
  <div class="container">
    <h2 class="mb-0"><i class="bi bi-heart me-2"></i>My Wishlist</h2>
  </div>
</div>

<div class="container py-4">
  <% if (wishlistItems.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-heart display-3 text-muted mb-3 d-block"></i>
      <h4>Your wishlist is empty</h4>
      <p class="text-muted">Browse products and click the heart icon to save items for later.</p>
      <a href="/" class="btn btn-primary btn-lg mt-2"><i class="bi bi-grid me-2"></i>Browse Products</a>
    </div>
  <% } else { %>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h5 class="mb-0 fw-bold"><%= wishlistItems.length %> saved item<%= wishlistItems.length !== 1 ? 's' : '' %></h5>
    </div>
    <div class="row g-3">
      <% wishlistItems.forEach(function(item) { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card border-0 shadow-sm h-100" style="border-radius:12px;overflow:hidden;">
            <a href="/product?id=<%= item.idP %>">
              <img src="<%= item.photoPath %>" alt="<%= item.labelP %>"
                style="width:100%;height:180px;object-fit:cover;background:#f0f2f5;"
                onerror="this.src='https://placehold.co/400x180/1a1a2e/00d4ff?text=<%= encodeURIComponent(item.category) %>'" />
            </a>
            <div class="card-body p-3">
              <span class="category-badge mb-1 d-inline-block"><%= item.category %></span>
              <div class="small text-muted mb-1"><%= item.brand %></div>
              <a href="/product?id=<%= item.idP %>" class="text-decoration-none text-dark">
                <div class="fw-semibold small mb-2" style="line-height:1.3;"><%= item.labelP %></div>
              </a>
              <div class="fw-bold text-primary mb-3">$<%= parseFloat(item.priceP).toFixed(2) %></div>
              <div class="d-flex gap-2">
                <form action="/add-to-cart" method="POST" class="flex-grow-1">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="idP" value="<%= item.idP %>" />
                  <input type="hidden" name="quantity" value="1" />
                  <button type="submit" class="btn btn-primary btn-sm w-100" <%= item.QtyP === 0 ? 'disabled' : '' %>>
                    <i class="bi bi-cart-plus me-1"></i><%= item.QtyP === 0 ? 'Out of Stock' : 'Add to Cart' %>
                  </button>
                </form>
                <form action="/wishlist/remove/<%= item.idW %>" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-outline-danger btn-sm" title="Remove from wishlist">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
