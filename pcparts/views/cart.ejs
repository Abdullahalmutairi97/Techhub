<% showHero = false; activeCategory = null; search = null; %>
<%- include('partials/header') %>
<div class="page-header"><div class="container"><h2 class="mb-0"><i class="bi bi-cart3 me-2"></i>Shopping Cart</h2></div></div>
<div class="container py-4">
  <% if (!user) { %>
    <div class="text-center py-5">
      <i class="bi bi-person-lock display-3 text-muted mb-3 d-block"></i>
      <h4>Please log in to view your cart</h4>
      <p class="text-muted">Your cart is saved to your account for easy access across devices.</p>
      <div class="d-flex gap-3 justify-content-center mt-3">
        <a href="/login" class="btn btn-primary btn-lg"><i class="bi bi-box-arrow-in-right me-2"></i>Login</a>
        <a href="/register" class="btn btn-outline-primary btn-lg"><i class="bi bi-person-plus me-2"></i>Register</a>
      </div>
    </div>
  <% } else if (cartItems.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-cart-x display-3 text-muted mb-3 d-block"></i>
      <h4>Your cart is empty</h4>
      <p class="text-muted">Looks like you haven't added anything yet. Start building your PC!</p>
      <a href="/" class="btn btn-primary btn-lg mt-2"><i class="bi bi-grid me-2"></i>Browse Products</a>
    </div>
  <% } else { %>
    <% const total = cartItems.reduce((s, i) => s + parseFloat(i.priceP) * i.quantity, 0); %>
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table cart-table mb-0 align-middle">
                <thead class="table-light">
                  <tr><th class="ps-4">Product</th><th class="text-center">Unit Price</th><th class="text-center">Quantity</th><th class="text-center">Subtotal</th><th></th></tr>
                </thead>
                <tbody>
                  <% cartItems.forEach(function(item) { %>
                  <tr>
                    <td class="ps-4">
                      <div class="d-flex align-items-center gap-3">
                        <img src="<%= item.photoPath %>" alt="<%= item.labelP %>" width="80" height="80"
                          style="object-fit:cover;border-radius:8px;background:#f0f2f5;"
                          onerror="this.src='https://placehold.co/80x80/f0f2f5/0d6efd?text=P'" />
                        <div>
                          <a href="/product?id=<%= item.idP %>" class="fw-semibold text-decoration-none text-dark"><%= item.labelP %></a>
                          <div class="small text-muted"><%= item.category %> · <%= item.brand %></div>
                        </div>
                      </div>
                    </td>
                    <td class="text-center fw-semibold">$<%= parseFloat(item.priceP).toFixed(2) %></td>
                    <td class="text-center">
                      <form action="/cart/update" method="POST" class="d-inline">
                        <input type="hidden" name="idCart" value="<%= item.idCart %>" />
                        <input type="number" name="quantity" value="<%= item.quantity %>" min="1" max="<%= item.QtyP %>"
                          class="form-control form-control-sm text-center" style="width:70px;display:inline-block;" onchange="this.form.submit()" />
                      </form>
                    </td>
                    <td class="text-center fw-bold text-primary">$<%= (parseFloat(item.priceP) * item.quantity).toFixed(2) %></td>
                    <td>
                      <form action="/cart/remove/<%= item.idCart %>" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this item?')"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="mt-3"><a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Continue Shopping</a></div>
      </div>
      <div class="col-lg-4">
        <div class="order-summary-card">
          <h5 class="fw-bold mb-3"><i class="bi bi-receipt me-2"></i>Order Summary</h5>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Items (<%= cartItems.reduce((s, i) => s + i.quantity, 0) %>)</span>
            <span class="fw-semibold">$<%= total.toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Shipping</span>
            <span class="text-success fw-semibold"><i class="bi bi-truck me-1"></i>Free</span>
          </div>
          <hr/>
          <div class="d-flex justify-content-between mb-4">
            <span class="fw-bold">Total</span>
            <span class="total-line">$<%= total.toFixed(2) %></span>
          </div>
          <a href="/checkout" class="btn btn-primary w-100 btn-lg"><i class="bi bi-lock me-2"></i>Proceed to Checkout</a>
          <p class="text-center text-muted small mt-3 mb-0"><i class="bi bi-shield-check me-1"></i>Secure checkout — SSL encrypted</p>
        </div>
      </div>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
